{
  "name": "repo-repos-capture-the-flag",
  "root": "repos/Capture-the-Flag",
  "projectType": "library",
  "targets": {
    "status": {
      "executor": "nx:run-commands",
      "options": {
        "command": "git -C repos/Capture-the-Flag status --short || true"
      },
      "metadata": {
        "supervisorRequired": true
      }
    },
    "fetch": {
      "executor": "nx:run-commands",
      "options": {
        "command": "git -C repos/Capture-the-Flag fetch --all --prune || true"
      },
      "metadata": {
        "supervisorRequired": true
      }
    },
    "log": {
      "executor": "nx:run-commands",
      "options": {
        "command": "git -C repos/Capture-the-Flag log --oneline -10 || true"
      },
      "metadata": {
        "supervisorRequired": true
      }
    },
    "manifests": {
      "executor": "nx:run-commands",
      "options": {
        "command": "find repos/Capture-the-Flag \\( -name package.json -o -name pyproject.toml -o -name Cargo.toml -o -name go.mod -o -name setup.py \\) -not -path '*/node_modules/*' -not -path '*/testdata/*' -not -path '*/fixtures/*' -print | sort"
      },
      "metadata": {
        "supervisorRequired": true
      }
    },
    "node-install": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sh -lc 'cd repos/Capture-the-Flag && npm install'"
      },
      "metadata": {
        "supervisorRequired": true
      }
    },
    "node-test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sh -lc 'cd repos/Capture-the-Flag && npm test --if-present'"
      },
      "metadata": {
        "supervisorRequired": true
      }
    },
    "node-build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sh -lc 'cd repos/Capture-the-Flag && npm run build --if-present'"
      },
      "metadata": {
        "supervisorRequired": true
      }
    },
    "node-lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sh -lc 'cd repos/Capture-the-Flag && npm run lint --if-present'"
      },
      "metadata": {
        "supervisorRequired": true
      }
    },
    "node-audit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sh -lc 'cd repos/Capture-the-Flag && npm audit --audit-level=high || true'"
      },
      "metadata": {
        "supervisorRequired": true
      }
    },
    "security-node": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sh -lc 'cd repos/Capture-the-Flag && npm audit --audit-level=high || true'"
      },
      "metadata": {
        "supervisorRequired": true
      }
    },
    "security": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sh -lc 'printf \"security targets: security-node\\n\"'"
      },
      "metadata": {
        "supervisorRequired": true
      }
    }
  },
  "tags": [
    "scope:repos",
    "type:subrepo",
    "lang:node"
  ]
}